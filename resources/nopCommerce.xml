<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="NopCommerce Automation Testing" >

    <listeners>
        <listener class-name="commons.MethodListener"></listener>
        <listener class-name="JiraConfig.JIRAListener"></listener>

    </listeners>
    
    <parameter name="userUrl" value="https://demo.nopcommerce.com"/>
    <parameter name="adminUrl" value="https://admin-demo.nopcommerce.com"/>
    <test name="Run on Chrome browser" preserve-order="true">

        <parameter name="browser" value="hfirefox" />
        <classes>
<!--            <class name="com.nopcommerce.com.Login"/>-->
            <class name="com.nopcommerce.uses.Level_21_Browser_Config"/>
        </classes>
    </test>

    <test name="Run on Chrome browser" preserve-order="true">

        <parameter name="browser" value="hchrome" />
        <classes>
            <!--            <class name="com.nopcommerce.com.Login"/>-->
            <class name="com.nopcommerce.uses.Level_21_Browser_Config"/>
        </classes>
    </test>
</suite>